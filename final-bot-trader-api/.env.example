# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=trader_user
DB_PASSWORD=trader_password
DB_NAME=final_bot_trader_db
DB_SSLMODE=disable

# Bitunix Exchange Configuration
BITUNIX_API_KEY=your_api_key_here
BITUNIX_SECRET_KEY=your_secret_key_here
BITUNIX_BASE_URL=https://fapi.bitunix.com

# Trading Configuration
DEFAULT_LEVERAGE=10
DEFAULT_MARGIN_TYPE=ISOLATED

# Telegram Notifications
# Get your bot token from @BotFather on Telegram
# Get your chat ID from @userinfobot or @getmyid_bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
